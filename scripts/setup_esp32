#!/usr/bin/env bash
# Flash an ESP32/ESP32-S3 with MicroPython and copy the selected firmware.
set -euo pipefail

usage() {
    cat >&2 <<'USAGE'
Usage: scripts/setup_esp32 [--sensor|-s dht11|dht22] [--board|-b esp32|esp32s3]

Defaults:
  sensor: dht11
  board: esp32

Environment:
  ESP32_PORT=/dev/ttyUSB0  Optional serial port override. When unset, the
                           script auto-detects one /dev/ttyUSB* or /dev/ttyACM*.
USAGE
}

detect_port() {
    local line port
    local ports=()

    while IFS= read -r line; do
        port="${line%% *}"
        case "$port" in
            /dev/ttyUSB*|/dev/ttyACM*)
                ports+=("$port")
                ;;
        esac
    done < <(mpremote connect list)

    case "${#ports[@]}" in
        0)
            echo "No ESP32 serial port detected. Connect a board or set ESP32_PORT=/dev/ttyUSBx." >&2
            exit 1
            ;;
        1)
            printf '%s\n' "${ports[0]}"
            ;;
        *)
            echo "Multiple ESP32 serial ports detected: ${ports[*]}" >&2
            echo "Set ESP32_PORT=/dev/ttyUSBx to choose one." >&2
            exit 1
            ;;
    esac
}

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SENSOR="dht11"
BOARD="esp32"

while (($#)); do
    case "$1" in
        --sensor|-s)
            if (($# < 2)); then
                echo "$1 requires a value: dht11 or dht22." >&2
                usage
                exit 2
            fi
            SENSOR="$2"
            shift 2
            ;;
        --board|-b)
            if (($# < 2)); then
                echo "$1 requires a value: esp32 or esp32s3." >&2
                usage
                exit 2
            fi
            BOARD="$2"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            usage
            exit 2
            ;;
    esac
done

if [[ -n "${ESP32_PORT:-}" ]]; then
    PORT="$ESP32_PORT"
    PORT_EXPLICIT=1
else
    PORT="$(detect_port)"
    PORT_EXPLICIT=0
fi

case "$SENSOR" in
    dht11|dht22)
        ;;
    *)
        echo "Unsupported sensor: $SENSOR. Use dht11 or dht22." >&2
        exit 2
        ;;
esac

case "$BOARD" in
    esp32)
        CHIP="esp32"
        FLASH_OFFSET="0x1000"
        FIRMWARE_PATH="$ROOT_DIR/esp32_firmware/mp-esp32-v1.28.0.bin"
        ;;
    esp32s3)
        CHIP="esp32s3"
        FLASH_OFFSET="0x0"
        FIRMWARE_PATH="$ROOT_DIR/esp32_firmware/mp-esp32s3-v1.28.0.bin"
        ;;
    *)
        echo "Unsupported board: $BOARD. Use esp32 or esp32s3." >&2
        exit 2
        ;;
esac

MAIN_PY="$ROOT_DIR/esp32_firmware/main_${SENSOR}.py"
SECRETS_PY="$ROOT_DIR/esp32_firmware/secrets.py"
UMQTTSIMPLE_PY="$ROOT_DIR/esp32_firmware/umqttsimple.py"

for path in "$FIRMWARE_PATH" "$MAIN_PY" "$SECRETS_PY" "$UMQTTSIMPLE_PY"; do
    if [[ ! -f "$path" ]]; then
        echo "Required file not found: $path" >&2
        exit 1
    fi
done

echo "Flashing $BOARD ($CHIP) with $SENSOR firmware on $PORT"
esptool --chip "$CHIP" --port "$PORT" erase-flash
esptool --chip "$CHIP" --port "$PORT" --baud 460800 write-flash "$FLASH_OFFSET" "$FIRMWARE_PATH"

# Native-USB boards (notably ESP32-S3 USB-Serial/JTAG) can disconnect and
# re-enumerate after esptool resets them. Wait before opening mpremote; opening
# first and then sleeping leaves mpremote holding a dead file descriptor.
POST_FLASH_WAIT="${SETUP_ESP32_POST_FLASH_WAIT:-5}"
if [[ "$POST_FLASH_WAIT" != "0" ]]; then
    echo "Waiting ${POST_FLASH_WAIT}s for $BOARD serial to re-enumerate..."
    sleep "$POST_FLASH_WAIT"
fi

if ((PORT_EXPLICIT == 0)); then
    PORT="$(detect_port)"
fi

echo "Copying firmware files over $PORT"

# Copy files to the MicroPython filesystem root where main.py imports
# secrets.py/umqttsimple.py.
mpremote connect "$PORT" \
    cp "$MAIN_PY" :main.py + \
    cp "$SECRETS_PY" :secrets.py + \
    cp "$UMQTTSIMPLE_PY" :umqttsimple.py + \
    reset
