# Telegram Bot Token
# Get yours from @BotFather on Telegram.
# The bot exits with an error if the token is unset.
TELEGRAM_BOT_TOKEN=your_bot_token_here
MQTT_BROKER=your_broker_address
MQTT_PORT=8080
MQTT_USER=your_mqtt_user
MQTT_PASS=your_mqtt_password
# Telegram chat id to receive automatic threshold-breach alerts (/alerts).
# If unset, alerts are logged but not sent.
ALERT_CHAT_ID=
